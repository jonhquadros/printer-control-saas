rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Basic Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isSuperAdmin() {
      return hasRole('SUPER_ADMIN');
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isClient() {
      return hasRole('CLIENT');
    }

    function isTechnician() {
      return hasRole('TECHNICIAN');
    }

    function isManager() {
      return hasRole('MANAGER');
    }

    function isGlobal() {
      return isSuperAdmin() || isTechnician() || isManager();
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserData().companyId == companyId;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Allow self-read and self-update
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow creation
      allow create: if isAuthenticated() && (
        // Self creation during register
        (request.auth.uid == userId) ||
        // Super admin can create any user
        isSuperAdmin() ||
        // Admin or Client or Manager can invite a CLIENT to their own company
        ((isAdmin() || isClient() || isManager()) && 
         request.resource.data.role == 'CLIENT' && 
         request.resource.data.companyId == getUserData().companyId)
      );

      // Admin access to company users
      allow read, update: if (isAdmin() || isManager()) && belongsToCompany(resource.data.companyId);
      
      // Super admin access
      allow read, write: if isSuperAdmin();
    }

    // Companies Collection
    match /companies/{companyId} {
      allow create: if isAuthenticated();
      allow read: if belongsToCompany(companyId) || isGlobal();
      allow update: if (isAdmin() && belongsToCompany(companyId)) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Audit Logs
    match /auditLogs/{logId} {
      // Allow any authenticated user to CREATE a log (as actions happen in UI)
      allow create: if isAuthenticated();
      
      // Allow read only for Admin (same company) or Super Admin
      allow read: if isSuperAdmin() || (isAdmin() && belongsToCompany(resource.data.companyId));
      
      // Block update and delete for EVERYONE - Logs are immutable
      allow update, delete: if false;
    }

    // Company Settings
    match /settings/{companyId} {
      allow read: if belongsToCompany(companyId) || isGlobal();
      allow write: if (isAdmin() && belongsToCompany(companyId)) || isSuperAdmin();
    }

    // In-App Notifications
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated(); 
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Special match for serviceOrders to allow Technician/Manager global access
    match /serviceOrders/{osId} {
       allow read, update: if isGlobal() || belongsToCompany(resource.data.companyId);
       allow create: if isGlobal() || belongsToCompany(request.resource.data.companyId);
    }

    // Special match for printers to allow Technician/Manager global access
    match /printers/{printerId} {
       allow read: if isGlobal() || belongsToCompany(resource.data.companyId);
       allow write: if isGlobal() || belongsToCompany(resource.data.companyId) || (request.resource != null && belongsToCompany(request.resource.data.companyId));
    }

    // Fallback for company-isolated collections (etc)
    match /{collection}/{document=**} {
      allow read, write: if isSuperAdmin();
      
      allow read, write: if (resource != null && belongsToCompany(resource.data.companyId)) || 
                            (request.resource != null && belongsToCompany(request.resource.data.companyId));
    }
  }
}
