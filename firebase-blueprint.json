{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Store tenant companies",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "plan": { "type": "string" }
      },
      "required": ["name", "cnpj", "status"]
    },
    "User": {
      "title": "User",
      "description": "Store users belonging to companies",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "TECHNICIAN", "CLIENT"] },
        "companyId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "companyId", "status"]
    },
    "Printer": {
      "title": "Printer",
      "description": "Store printer equipment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "serialNumber": { "type": "string" },
        "companyId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "MAINTENANCE"] },
        "currentCounter": { "type": "number" }
      },
      "required": ["name", "serialNumber", "companyId", "status"]
    },
    "ServiceOrder": {
      "title": "ServiceOrder",
      "description": "Store service orders",
      "type": "object",
      "properties": {
        "number": { "type": "number" },
        "companyId": { "type": "string" },
        "printerId": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "PENDING", "COMPLETED", "CANCELLED"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "companyId", "printerId", "status"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Store system logs and audit trail",
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "companyId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["module", "action", "timestamp"]
    }
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Company documents"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/printers/{printerId}": {
      "schema": "Printer",
      "description": "Printer documents"
    },
    "/serviceOrders/{orderId}": {
      "schema": "ServiceOrder",
      "description": "Service Order documents"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit log documents"
    }
  }
}
